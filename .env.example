# ============================================================
# ClothWorkFlow Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# Required for image analysis (Step 2)
OPENROUTER_API_KEY=your-openrouter-api-key

# Required for web scraping (Step 1)
AWS_BEARER_TOKEN_BEDROCK=your-aws-token
AWS_REGION=us-east-1

# Optional: Google AI Studio — 项目根 .env 中设置 GEMINI_API_KEY 即可：
# - 后端智能搭配（需 python-dotenv，随 pip install -e . 安装；重启 API）
# - 前端 AI 试衣（Vite 会映射为 VITE_GEMINI_API_KEY；改后请重启 npm run dev 或重新 build）
# GEMINI_API_KEY=your-google-ai-studio-api-key
# Optional override for intent model (default: gemini-3-flash-preview)
# GEMINI_SEARCH_INTENT_MODEL=gemini-3-flash-preview
# Optional: 生图模型，同时映射到 VITE_GEMINI_IMAGE_MODEL
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Optional: set to 0 to skip auto-loading the first analysis dataset on API startup (load via Smart Search UI instead)
# CLOTHWORKFLOW_AUTO_LOAD=0

# Optional: custom model paths (auto-downloaded from HuggingFace if not set)
# If you have pre-downloaded models, set these to local paths
# BGE_M3_PATH=/path/to/bge-m3
# BGE_RERANKER_PATH=/path/to/bge-reranker-v2-m3

# ------------------------------------------------------------
# Frontend — 可选：仅在不想用根目录 .env 时，再在 clothworkflow/web/.env 写 VITE_GEMINI_API_KEY
# ------------------------------------------------------------
# VITE_GEMINI_API_KEY=your-google-ai-studio-api-key
# VITE_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
